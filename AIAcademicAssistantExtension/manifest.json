
{
  "manifest_version": 3,
  "name": "AI Tool Recommender",
  "version": "1.0",
  "description": "Recommends the best AI tool for your task and builds optimised prompts",
  "permissions": ["activeTab", "storage", "alarms", "scripting"],
  "host_permissions": [ 
    "http://localhost:7700/*",
    "https://w19929235-fyp.hf.space:7860/*",
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.midjourney.com/*",
    "https://github.com/features/copilot/*",
    "https://www.perplexity.ai/*",
    "https://www.anthropic.com/*",
    "https://platform.openai.com/*"
    ],
  
  "action": {
    "default_icon": "icon3.png"
  },

   "background": {
    "service_worker": "background.js"
  },
  
"web_accessible_resources": [
    {
      "resources": ["tools.json", "popup.html", "popup.js", "styles.css", "settings.html", "settings.js"],
      "matches": ["<all_urls>"]
    }
  ]


}